msgid "Authentication required"
msgstr "ຈຳເປັນຕ້ອງມີການຢືນຢັນຕົວຕົນ"

#. TRANSLATORS: This is a status message, shown when the system is checking
#. the users password
msgid "Checking password …"
msgstr "ກຳລັງກວດສອບລະຫັດຜ່ານ..."

msgid "Confirm"
msgstr "ຢືນຢັນ"

msgid "Password"
msgstr "ລະຫັດຜ່ານ"

msgid "Please enter your password"
msgstr "ກະລຸນາປ້ອນລະຫັດຜ່ານຂອງທ່ານ"

msgid ""
"This action needs authentication, please confirm it by entering your "
"password."
msgstr ""
"ການດຳເນີນການນີ້ຈຳເປັນຕ້ອງມີການຢືນຢັນຕົວຕົນ, "
"ກະລຸນາຢືນຢັນໂດຍການປ້ອນລະຫັດຜ່ານຂອງທ່ານ."

msgid "Wrong password"
msgstr "ລະຫັດຜ່ານບໍ່ຖືກຕ້ອງ"
